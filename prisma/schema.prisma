generator client {
  provider = "prisma-client-js"
}

// Prisma 7 : url/directUrl sont définis dans prisma.config.ts, pas ici.
datasource db {
  provider = "postgresql"
}

// ─── Produits ─────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  name        String
  description String      @default("")
  price       Float
  image       String      @default("")
  category    String
  featured    Boolean     @default(false)
  stockS      Int         @default(0)
  stockM      Int         @default(0)
  stockL      Int         @default(0)
  stockXL     Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  savedCarts  SavedCart[]
}

// ─── Commandes ────────────────────────────────────────────────────────────────

model Order {
  id        String      @id @default(cuid())
  date      DateTime    @default(now())
  userId    String?     // Optionnel : null = commande invité
  subtotal  Float
  discount  Float       @default(0)
  tva       Float
  total     Float
  status    String      @default("En attente")
  source    String      @default("en_ligne")
  items     OrderItem[]
  profile   Profile?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  size      String?
  price     Float
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

// ─── Utilisateurs & Rôles ─────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

model Profile {
  id        String   @id
  email     String   @unique
  role      Role     @default(USER)
  orders    Order[]
  cartItems SavedCart[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Panier sauvegardé en base par utilisateur
model SavedCart {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  size      String?
  profile   Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, size])
}
